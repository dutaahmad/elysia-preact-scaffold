{
  "name": "elysia-preact-scaffold",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"vite,elysia\" -c \"cyan,green\" \"vite\" \"bun run --watch server/index.ts\"",
    "dev:fe": "vite",
    "dev:be": "bun run --watch server/index.ts",
    "build": "vite build",
    "preview": "NODE_ENV=production bun run server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@elysia/static": "^1.4.11",
    "@inquirer/prompts": "^8.5.2",
    "@phosphor-icons/react": "^2.1.7",
    "@stisla/css": "^3.0.1",
    "@stisla/vanilla": "^3.0.2",
    "@tanstack/preact-query": "^5.101.2",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.29",
    "preact": "^10.29.3",
    "tailwind-merge": "^3.6.0",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.4",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.1.7",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.1.7",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
